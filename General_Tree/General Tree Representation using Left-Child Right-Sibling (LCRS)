#include <iostream>
using namespace std;

// Node structure
// This is actually representing a GENERAL TREE
// using Left Child Right Sibling method
// lc -> first child
// rc -> next sibling
struct bstnode {
	char data;
	bstnode* rc,*lc;
};

bstnode* root=NULL;

// Simple queue structure for level order traversal
struct queue{
    bstnode* arr[50];  // fixed size queue (enough for this problem)
    int r=-1,f=-1;     // r -> rear, f -> front
}q;

// Enqueue function
void enque(queue&q,bstnode*root){
    // if queue is empty
    if(q.f==-1){
        q.f=0;
        q.r=0;
    }else{
        q.r++;
    }
    q.arr[q.r]=root;
}

// Dequeue function
bstnode* deque(queue &q){
    if(q.r==-1) return NULL; // queue empty
    
    bstnode *res=q.arr[q.f];
    
    // if only one element was present
    if(q.r==q.f){
        q.f=-1;
        q.r=-1;
    }else{
        q.f++;
    }
    return res;
}

/*
create function

This builds the General Tree from preorder string.
'.' means NULL.

Important:
Since this is LCRS representation:
- First recursive call creates FIRST CHILD (lc)
- Second recursive call creates NEXT SIBLING (rc)

So structure becomes:
lc -> first child
rc -> next sibling
*/
void create(bstnode* &root,string s,int &i){
    i++;   // move to next character
    
    if(s[i]=='.'){   // if null node
        return;
    }
    
    root=new bstnode;
    root->data=s[i];
    root->lc=root->rc=NULL;
    
    // create first child
    create(root->lc,s,i);
    
    // create next sibling
    create(root->rc,s,i);
}

/*
Level Order Traversal

Since this is General Tree stored as Binary Tree:
- We print one node
- Then move through its siblings using rc
- For each sibling, we enqueue its first child (lc)

NULL is used to mark end of level.
'*' is printed after every level.
*/
void levelorder(bstnode *root){
    queue q;
    
    enque(q,root);
    enque(q,NULL);   // level marker
    
    while(q.r!=-1){
        bstnode *temp=deque(q);
        
        if(temp!=NULL){
            
            // move through siblings at same level
            while(temp!=NULL){
                
                cout<<temp->data<<" ";
                
                // enqueue first child of each sibling
                if(temp->lc)
                    enque(q,temp->lc);
                
                // move to next sibling
                temp=temp->rc;
            }
        }
        else{
            // reached end of one level
            
            if(q.r==-1){
                cout<<"*";
                return;
            }else{
                cout<<"*"<<endl;
                enque(q,NULL);  // add marker for next level
            }
        }
    }
}

int main(){
    int i=-1;
    string s;
    
    cin>>s;   // preorder input with '.'
    
    create(root,s,i);   // build tree
    
    levelorder(root);   // print level order
    
    return 0;
}
